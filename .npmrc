# pnpm config
# Hoist packages needed by Next.js WASM webpack plugins to the root node_modules.
# Without this, Next.js can't resolve webpack loaders across workspace boundaries.
shamefully-hoist=false
public-hoist-pattern[]=*webpack*
public-hoist-pattern[]=*next*
public-hoist-pattern[]=*tailwind*
public-hoist-pattern[]=*postcss*

# Suppress strict peer-dependency errors from CoFHE / Aleo packages
# that haven't updated their peer dep ranges yet.
strict-peer-dependencies=false
auto-install-peers=true
