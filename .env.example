# hardware-relayer 環境變數
# 複製這個檔案為 .env，填入真實值，不要 commit .env

# 有 ETH 的錢包私鑰（用來 submit reward transaction）
EVM_PRIVATE_KEY=0x...

# Ethereum Sepolia RPC（可用 Alchemy / Infura 免費方案）
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# RewardDistributor 合約地址
REWARD_DISTRIBUTOR_ADDRESS=0x...

# 設備上報的 API 認證金鑰（自定義，留空則不驗證）
API_KEY=your-secret-key
